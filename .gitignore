# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
# IMPORTANT: .env.local contient les secrets - ne JAMAIS commiter
# Créez un fichier .env.local MANUELLEMENT sur le serveur ou dans Railway variables

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# local mock data & logs
/src/data/orders.json
/src/data/sent_emails.json

# SQLite journal (les fichiers temporaires, mais pas dev.db lui-même)
prisma/*.db-journal
prisma/*.db-wal
prisma/*.db-shm
# NOTE: prisma/dev.db est inclus dans git pour que Railway ait une DB initiale

